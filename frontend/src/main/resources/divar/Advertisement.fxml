<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.controller.AdvertisementController" prefWidth="1050" prefHeight="700"
            stylesheets="@../css/style.css">
    <top>
        <HBox alignment="CENTER_RIGHT" styleClass="detail-header">
            <padding><Insets top="18" right="28" bottom="18" left="28"/></padding>
            <Label text="جزئیات آگهی" styleClass="brand-mark"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="بازگشت به آگهی‌ها" styleClass="ghost-button" onAction="#back"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="detail-scroll">
            <content>
                <VBox spacing="18" styleClass="detail-shell">
                    <padding><Insets top="28" right="36" bottom="36" left="36"/></padding>
                    <HBox spacing="28" alignment="TOP_RIGHT">
                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                            <ScrollPane fitToHeight="true"
                                        fitToWidth="true"
                                        prefHeight="220"
                                        hbarPolicy="AS_NEEDED">

                                <HBox fx:id="imageGallery"
                                      spacing="10"
                                      alignment="CENTER_LEFT"/>

                            </ScrollPane>
                            <Label fx:id="titleLabel" styleClass="detail-title" wrapText="true"/>
                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <Label fx:id="priceLabel" styleClass="detail-price"/>
                                <Label fx:id="statusLabel" styleClass="status-pill"/>
                            </HBox>
                            <HBox spacing="18" styleClass="meta-row">
                                <Label fx:id="cityLabel"/>
                                <Label fx:id="categoryLabel"/>
                            </HBox>
                            <Separator/>
                            <Label text="توضیحات" styleClass="section-title"/>
                            <TextArea fx:id="descriptionArea" editable="false" wrapText="true" prefHeight="220" styleClass="detail-description"/>
                        </VBox>
                        <VBox prefWidth="260" spacing="12" styleClass="seller-card">
                            <Label text="فروشنده" styleClass="card-caption"/>
                            <Label fx:id="ownerLabel" styleClass="seller-name" wrapText="true"/>
                            <Label fx:id="rateLabel" styleClass="seller-rate"/>
                            <Label fx:id="messageLabel" styleClass="error" wrapText="true"/>
                        </VBox>
                    </HBox>
                    <HBox fx:id="ownerActionsBox" spacing="10" alignment="CENTER_RIGHT" managed="false" visible="false" styleClass="actions-bar">
                        <Button text="ویرایش" styleClass="ghost-button" onAction="#editAdvertisement"/>
                        <Button fx:id="markSoldButton" text="فروخته شد" styleClass="primary-button" onAction="#markAsSold"/>
                        <Button text="حذف آگهی" styleClass="danger-button" onAction="#deleteAdvertisement"/>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
