<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="divar.controller.MessageControllerFront">

    <top>

        <HBox alignment="CENTER_LEFT">

            <padding>
                <Insets top="10"
                        right="10"
                        left="10"
                        bottom="10"/>
            </padding>

            <Label text="Chat with "/>

            <Label fx:id="lblUser"
                   style="-fx-font-weight:bold;
                          -fx-font-size:16px;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="Refresh"
                    onAction="#refresh"/>

        </HBox>
        <HBox alignment="CENTER_LEFT" styleClass="detail-header">

            <padding>
                <Insets top="15" right="20" left="20" bottom="15"/>
            </padding>

            <Button text="← بازگشت"
                    onAction="#back"
                    styleClass="ghost-button"/>

            <Label fx:id="lblUser"
                   styleClass="detail-title"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="⟳"
                    onAction="#refresh"
                    styleClass="ghost-button"/>

        </HBox>
    </top>

    <center>

        <ListView fx:id="messageList"/>

    </center>

    <bottom>

        <HBox spacing="10">

            <padding>
                <Insets top="10"
                        right="10"
                        left="10"
                        bottom="10"/>
            </padding>

            <TextField fx:id="txtMessage"
                       promptText="Type your message..."
                       HBox.hgrow="ALWAYS"/>

            <Button fx:id="btnSend"
                    text="Send"
                    onAction="#sendMessage"/>

        </HBox>

    </bottom>

</BorderPane>