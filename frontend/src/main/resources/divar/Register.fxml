<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.controller.RegisterController"
            prefWidth="1200" prefHeight="700"
            nodeOrientation="RIGHT_TO_LEFT"
            stylesheets="@../css/style.css">

    <right>
        <StackPane prefWidth="460" styleClass="login-brand-panel">
            <VBox alignment="CENTER" spacing="18" maxWidth="350">
                <Label text="دیوار" styleClass="login-logo"/>
                <Label text="خرید و فروش ساده، سریع و مطمئن" styleClass="login-brand-subtitle"/>
                <Separator maxWidth="230" opacity="0.45"/>
                <Label text="به جمع دیواری‌ها بپیوندید" styleClass="login-brand-title"/>
                <Label text="حساب کاربری خودت را بساز، آگهی ثبت کن و خرید و فروش را ساده‌تر تجربه کن." styleClass="login-brand-description" wrapText="true" textAlignment="CENTER"/>
            </VBox>
        </StackPane>
    </right>

    <center>
        <StackPane styleClass="login-page">
            <VBox alignment="CENTER" spacing="16" maxWidth="500" styleClass="login-card" nodeOrientation="RIGHT_TO_LEFT">
                <Label text="ساخت حساب کاربری" styleClass="login-title" textAlignment="RIGHT"/>
                <Label text="برای شروع اطلاعات خود را وارد کنید" styleClass="login-subtitle" textAlignment="RIGHT"/>

                <GridPane hgap="14" vgap="12" maxWidth="Infinity">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50"/>
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50"/>
                    </columnConstraints>

                    <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="نام و نام خانوادگی" styleClass="login-field-label"/>
                        <TextField fx:id="fullNameField" promptText="نام و نام خانوادگی" styleClass="login-input"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="نام کاربری" styleClass="login-field-label"/>
                        <TextField fx:id="usernameField" promptText="نام کاربری" styleClass="login-input"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="شماره تماس" styleClass="login-field-label"/>
                        <TextField fx:id="phoneField" promptText="09123456789" styleClass="login-input"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="ایمیل" styleClass="login-field-label"/>
                        <TextField fx:id="emailField" promptText="example@email.com" styleClass="login-input"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="رمز عبور" styleClass="login-field-label"/>
                        <PasswordField fx:id="passwordField" promptText="حداقل ۶ کاراکتر" styleClass="login-input"/>
                    </VBox>

                    <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="تکرار رمز عبور" styleClass="login-field-label"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="تکرار رمز عبور" styleClass="login-input" onAction="#register"/>
                    </VBox>
                </GridPane>

                <Button fx:id="registerButton" text="ساخت حساب کاربری" maxWidth="Infinity" styleClass="login-button" onAction="#register"/>
                <Label fx:id="messageLabel" styleClass="error" wrapText="true" maxWidth="420" textAlignment="CENTER"/>

                <Separator/>
                <HBox alignment="CENTER" spacing="5">
                    <Label text="قبلاً حساب ساخته‌اید؟" styleClass="login-muted"/>
                    <Hyperlink text="وارد شوید" onAction="#goToLogin"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
