<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.controller.HomeController"
            prefWidth="1200"
            prefHeight="700"
            styleClass="root"
            stylesheets="@../css/style.css">

    <center>

        <StackPane>

            <children>

                <VBox alignment="CENTER"
                      spacing="16"
                      maxWidth="460"
                      styleClass="card">

                    <padding>
                        <Insets top="45" right="45" bottom="45" left="45"/>
                    </padding>

                    <Label
                            fx:id="welcomeLabel"
                            styleClass="title"/>

                    <Label
                            wrapText="true"
                            maxWidth="360"
                            textAlignment="CENTER"
                            text="ورود شما با موفقیت انجام شد. صفحه اصلی آگهی‌ها در مراحل بعدی این‌جا تکمیل می‌شود."
                            styleClass="subtitle"/>

                    <Separator prefWidth="250"/>

                    <Button
                            text="خروج از حساب کاربری"
                            styleClass="button, button-secondary"
                            onAction="#logout"/>

                </VBox>

            </children>

        </StackPane>

    </center>

</BorderPane>
