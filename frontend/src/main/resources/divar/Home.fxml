<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.controller.HomeController" prefWidth="1280" prefHeight="760"
            nodeOrientation="RIGHT_TO_LEFT"
            stylesheets="@../css/style.css">
    <top>
        <VBox styleClass="home-header" spacing="16">
            <padding><Insets top="18" right="32" bottom="18" left="32"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="14">
                <Label text="ШҜЫҢЩҲШ§Шұ" styleClass="brand-mark"/>
                <Label fx:id="welcomeLabel" styleClass="welcome-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="loginButton"
                        text="ЩҲШұЩҲШҜ"
                        styleClass="primary-button"
                        onAction="#openLogin"/>

                <Button fx:id="registerButton"
                        text="Ш«ШЁШӘ ЩҶШ§Щ…"
                        styleClass="ghost-button"
                        onAction="#openRegister"/>

                <Button fx:id="createAdButton"
                        text="Ш«ШЁШӘ ШўЪҜЩҮЫҢ"
                        styleClass="primary-button"
                        onAction="#createAdvertisement"/>

                <Button fx:id="conversationButton"
                        text="ЪҜЩҒШӘЪҜЩҲЩҮШ§"
                        styleClass="ghost-button"
                        onAction="#openConversations"/>

                <Button fx:id="favoriteButton"
                        text="Ш№Щ„Ш§ЩӮЩҮвҖҢЩ…ЩҶШҜЫҢвҖҢЩҮШ§"
                        styleClass="ghost-button"
                        onAction="#openFavorites"/>

                <Button fx:id="logoutButton"
                        text="Ш®ШұЩҲШ¬"
                        styleClass="ghost-button"
                        onAction="#logout"/>
                <Button fx:id="adminPanelButton"
                        text="ЩҫЩҶЩ„ Щ…ШҜЫҢШұЫҢШӘ"
                        styleClass="ghost-button"
                        onAction="#openAdminPanel"/>
            </HBox>
            <VBox spacing="6" alignment="CENTER_LEFT">
                <Label text="ЩҮШұ ЪҶЫҢШІЫҢ Ъ©ЩҮ Щ„Ш§ШІЩ… ШҜШ§ШұЫҢШҢ ЩҮЩ…ЫҢЩҶвҖҢШ¬Ш§ШіШӘ" styleClass="hero-title"/>
                <Label text="ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢ Ш¬ШҜЫҢШҜ ШұШ§ ЩҫЫҢШҜШ§ Ъ©ЩҶ ЫҢШ§ Ъ©Ш§Щ„Ш§ЫҢ Ш®ЩҲШҜШӘ ШұШ§ ШЁШұШ§ЫҢ ЩҒШұЩҲШҙ Ш«ШЁШӘ Ъ©ЩҶ." styleClass="hero-subtitle"/>
            </VBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="рҹ”Қ Ш¬ШіШӘвҖҢЩҲШ¬ЩҲ ШҜШұ Ш№ЩҶЩҲШ§ЩҶ ЩҲ ШӘЩҲШ¶ЫҢШӯШ§ШӘ ШўЪҜЩҮЫҢ..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="sortComboBox" promptText="Щ…ШұШӘШЁвҖҢШіШ§ШІЫҢ" styleClass="sort-combo"/>
                <Button text="ШӘШ§ШІЩҮвҖҢШіШ§ШІЫҢ" styleClass="ghost-button" onAction="#refresh"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="14" styleClass="content-shell">
            <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>
            <HBox alignment="CENTER_LEFT">
                <Label text="ШўШ®ШұЫҢЩҶ ШўЪҜЩҮЫҢвҖҢЩҮШ§" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="resultCountLabel" styleClass="result-count"/>
            </HBox>
            <StackPane VBox.vgrow="ALWAYS">
                <ListView fx:id="advertisementListView" styleClass="ads-list"/>
                <VBox fx:id="emptyStateBox" alignment="CENTER" spacing="8" visible="false" managed="false">
                    <Label text="рҹ”Қ" styleClass="empty-state-icon"/>
                    <Label text="ШўЪҜЩҮЫҢвҖҢШ§ЫҢ ЩҫЫҢШҜШ§ ЩҶШҙШҜ" styleClass="empty-state-title"/>
                    <Label text="Ш№ШЁШ§ШұШӘ Ш¬ШіШӘвҖҢЩҲШ¬ЩҲ ЫҢШ§ ЩҒЫҢЩ„ШӘШұ ШұШ§ ШӘШәЫҢЫҢШұ ШЁШҜЩҮ ЩҲ ШҜЩҲШЁШ§ШұЩҮ Ш§Щ…ШӘШӯШ§ЩҶ Ъ©ЩҶ" styleClass="empty-state-subtitle"/>
                </VBox>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
