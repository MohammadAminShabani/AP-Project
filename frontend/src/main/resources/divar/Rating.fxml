<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.controller.RatingController" prefWidth="560" prefHeight="560"
            stylesheets="@../css/style.css">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="detail-header">
            <padding><Insets top="18" right="28" bottom="18" left="28"/></padding>
            <Button text="بازگشت" onAction="#back" styleClass="ghost-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="امتیازدهی به فروشنده" styleClass="brand-mark"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_RIGHT" spacing="16" styleClass="form-card">
            <padding><Insets top="30" right="40" bottom="36" left="40"/></padding>

            <Label fx:id="adTitleLabel" styleClass="form-title" wrapText="true"/>
            <Label fx:id="sellerNameLabel" styleClass="hero-subtitle"/>

            <Separator/>

            <Label text="امتیاز (۱ تا ۵)" styleClass="field-label"/>
            <Spinner fx:id="scoreSpinner" styleClass="form-input" maxWidth="140" />

            <Label text="نظر (اختیاری)" styleClass="field-label"/>
            <TextArea fx:id="commentField" prefHeight="140" wrapText="true"
                      promptText="تجربه‌ات از خرید را بنویس..." styleClass="form-input" nodeOrientation="RIGHT_TO_LEFT"/>

            <Label fx:id="messageLabel" styleClass="error" wrapText="true"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="ثبت امتیاز" onAction="#submitRating" styleClass="primary-button"/>
                <Button text="انصراف" onAction="#back" styleClass="ghost-button"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
