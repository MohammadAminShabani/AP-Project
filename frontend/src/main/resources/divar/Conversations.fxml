<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.controller.ConversationControllerFront" prefWidth="900" prefHeight="680"
            nodeOrientation="RIGHT_TO_LEFT"
            stylesheets="@../css/style.css">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="detail-header">
            <padding><Insets top="18" right="28" bottom="18" left="28"/></padding>
            <Button text="بازگشت به خانه" onAction="#back" styleClass="ghost-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="گفتگوهای من" styleClass="brand-mark"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⟳ تازه‌سازی" onAction="#refresh" styleClass="ghost-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="content-shell">
            <padding><Insets top="20" right="28" bottom="20" left="28"/></padding>
            <Label text="روی هر گفتگو دوبار کلیک کن تا وارد آن شوی." styleClass="hero-subtitle"/>
            <ListView fx:id="conversationList" styleClass="ads-list" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

</BorderPane>
