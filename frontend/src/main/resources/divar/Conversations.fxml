<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="divar.controller.ConversationControllerFront">

    <top>

        <HBox spacing="10"
              alignment="CENTER_LEFT">

            <padding>
                <Insets top="10"
                        right="10"
                        left="10"
                        bottom="10"/>
            </padding>

            <Label text="My Conversations"
                   style="-fx-font-size:20px;
                          -fx-font-weight:bold;"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="Refresh"
                    onAction="#refresh"/>

        </HBox>

    </top>

    <center>

        <ListView fx:id="conversationList"/>

    </center>

    <bottom>

        <HBox alignment="CENTER"
              spacing="10">

            <padding>
                <Insets top="10"
                        bottom="10"/>
            </padding>

            <Button text="Open Chat"
                    onAction="#openChat"/>

        </HBox>

    </bottom>

</BorderPane>