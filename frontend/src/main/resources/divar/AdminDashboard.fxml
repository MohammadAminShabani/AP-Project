<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.controller.AdminDashboardController"
            prefWidth="1250"
            prefHeight="750"
            styleClass="root"
            stylesheets="@../css/style.css">

    <!-- ================= LEFT MENU ================= -->

    <left>

        <AnchorPane prefWidth="280"
                    styleClass="left-panel">

            <children>

                <VBox spacing="18"
                      alignment="TOP_CENTER"
                      AnchorPane.topAnchor="20"
                      AnchorPane.bottomAnchor="20"
                      AnchorPane.leftAnchor="20"
                      AnchorPane.rightAnchor="20">

                    <Label
                            text="پنل مدیریت"
                            styleClass="logo"/>

                    <Separator prefWidth="220"/>

                    <Label
                            fx:id="adminLabel"
                            styleClass="subtitle"/>

                    <Button
                            fx:id="usersButton"
                            prefWidth="220"
                            prefHeight="42"
                            text="👤 مدیریت کاربران"
                            onAction="#showUsers"/>

                    <Button
                            fx:id="adsButton"
                            prefWidth="220"
                            prefHeight="42"
                            text="📢 مدیریت آگهی‌ها"
                            onAction="#showAdvertisements"/>

                    <Button
                            fx:id="blockedButton"
                            prefWidth="220"
                            prefHeight="42"
                            text="🚫 کاربران بلاک شده"
                            onAction="#showBlockedUsers"/>

                    <Separator prefWidth="220"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Button
                            prefWidth="220"
                            prefHeight="42"
                            text="🚪 خروج"
                            onAction="#logout"/>

                </VBox>

            </children>

        </AnchorPane>

    </left>

    <!-- ================= RIGHT CONTENT ================= -->

    <center>

        <StackPane fx:id="contentPane">

            <children>

                <BorderPane maxWidth="900"
                            maxHeight="650"
                            styleClass="card">

                    <center>

                        <VBox alignment="CENTER"
                              spacing="20">

                            <Label
                                    text="پنل مدیریت دیوار"
                                    styleClass="title"/>

                            <Label
                                    text="از منوی سمت چپ یکی از بخش‌ها را انتخاب کنید."
                                    styleClass="subtitle"/>

                        </VBox>

                    </center>

                </BorderPane>

            </children>

        </StackPane>

    </center>

</BorderPane>