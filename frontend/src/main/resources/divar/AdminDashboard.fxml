<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.controller.AdminControllerFront"
            nodeOrientation="RIGHT_TO_LEFT"
            prefWidth="1000.0" prefHeight="650.0">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="پنل مدیریت" styleClass="title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="messageLabel" style="-fx-text-fill:#c0392b;"/>

            <Button text="بازگشت" onAction="#back"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <Tab text="آگهی‌های در انتظار بررسی">
                <VBox spacing="10">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <ListView fx:id="pendingAdsListView" VBox.vgrow="ALWAYS"/>

                    <HBox spacing="10">
                        <Button text="تایید آگهی" onAction="#approveSelectedAd"/>
                        <Button text="رد آگهی" onAction="#rejectSelectedAd"/>
                        <Button text="حذف آگهی" onAction="#deleteSelectedAd"/>
                        <Button text="بروزرسانی" onAction="#refreshAds"/>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="کاربران">
                <VBox spacing="10">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>

                    <ListView fx:id="usersListView" VBox.vgrow="ALWAYS"/>

                    <HBox spacing="10">
                        <Button text="مسدود کردن کاربر" onAction="#blockSelectedUser"/>
                        <Button text="رفع مسدودی کاربر" onAction="#unblockSelectedUser"/>
                        <Button text="بروزرسانی" onAction="#refreshUsers"/>
                    </HBox>
                </VBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
